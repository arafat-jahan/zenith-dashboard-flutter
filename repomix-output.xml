            child: Text('Cancel'),
          ),
          TextButton(
            onPressed: () => Navigator.of(context).pop(true),
            child: Text('Change Plan'),
          ),
        ],
      ),
    );

    if (confirmed == true) {
      try {
        await admin.toggleUserPlan(userId, currentPlan);
        if (mounted) {
