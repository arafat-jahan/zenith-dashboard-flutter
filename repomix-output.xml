              ),
            ),
          ),
          // Glow orb 2
          Positioned(
            bottom: -80, right: -80,
            child: ScaleTransition(
              scale: _orb2Scale,
              child: Container(
                width: 300, height: 300,
                decoration: BoxDecoration(
                  shape: BoxShape.circle,
                  color: AppColors.accentBlue.withValues(alpha: 0.12),
